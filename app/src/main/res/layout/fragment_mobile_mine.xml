<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/mobile_space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemSetting"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shape_mobile_search"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:text="设置"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_lg" />

        <TextView
            android:id="@+id/itemConfig"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/mobile_space_md"
            android:background="@drawable/shape_mobile_search"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:text="配置地址"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_lg" />

        <TextView
            android:id="@+id/itemLine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/mobile_space_md"
            android:background="@drawable/shape_mobile_search"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:text="线路切换"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_lg" />

        <TextView
            android:id="@+id/itemUiMode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/mobile_space_md"
            android:background="@drawable/shape_mobile_search"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:text="操作偏好"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_lg" />

        <TextView
            android:id="@+id/itemCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/mobile_space_md"
            android:background="@drawable/shape_mobile_search"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:text="检查更新"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_lg" />

        <TextView
            android:id="@+id/tvUiModeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mobile_space_xs"
            android:paddingLeft="@dimen/mobile_space_lg"
            android:textColor="@color/color_BBFFFFFF"
            android:textSize="@dimen/mobile_text_sm" />
    </LinearLayout>
</ScrollView>
