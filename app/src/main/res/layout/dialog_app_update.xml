<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_dialog_bg_main"
    android:minWidth="280dp"
    android:orientation="vertical"
    android:padding="@dimen/mobile_space_lg">

    <TextView
        android:id="@+id/tvUpdateTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="发现新版本"
        android:textColor="@color/color_CC000000"
        android:textSize="@dimen/mobile_text_title"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUpdateVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/mobile_space_sm"
        android:textColor="@color/color_CC000000"
        android:textSize="@dimen/mobile_text_md" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/mobile_space_sm">

        <TextView
            android:id="@+id/tvUpdateChangelog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.3"
            android:textColor="@color/color_CC000000"
            android:textSize="@dimen/mobile_text_sm" />
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressUpdate"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/mobile_space_md"
        android:max="100"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvUpdateProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/mobile_space_xs"
        android:gravity="center"
        android:textColor="@color/color_CC000000"
        android:textSize="@dimen/mobile_text_sm"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/mobile_space_md"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnUpdateLater"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/button_update_secondary"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusLeft="@id/btnUpdateNow"
            android:nextFocusRight="@id/btnUpdateNow"
            android:paddingLeft="@dimen/mobile_space_md"
            android:paddingRight="@dimen/mobile_space_md"
            android:text="稍后"
            android:textColor="@color/text_update_secondary"
            android:textSize="@dimen/mobile_text_md" />

        <TextView
            android:id="@+id/btnUpdateNow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginLeft="@dimen/mobile_space_md"
            android:background="@drawable/button_update_primary"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusLeft="@id/btnUpdateLater"
            android:nextFocusRight="@id/btnUpdateLater"
            android:paddingLeft="@dimen/mobile_space_md"
            android:paddingRight="@dimen/mobile_space_md"
            android:text="立即更新"
            android:textColor="@color/color_FFFFFF"
            android:textSize="@dimen/mobile_text_md"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
