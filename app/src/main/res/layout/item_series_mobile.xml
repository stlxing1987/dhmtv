<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/mobile_space_xs"
    android:background="@drawable/shape_mobile_search">

    <TextView
        android:id="@+id/tvSeries"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:minWidth="48dp"
        android:paddingLeft="@dimen/mobile_space_sm"
        android:paddingRight="@dimen/mobile_space_sm"
        android:textColor="@android:color/white"
        android:textSize="@dimen/mobile_text_sm" />
</FrameLayout>
