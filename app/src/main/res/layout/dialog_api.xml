<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/dialogContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:orientation="horizontal"
        android:padding="@dimen/vs_30">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="扫码远程推送"
                android:textColor="@color/color_CC000000"
                android:textSize="@dimen/ts_22" />

            <ImageView
                android:id="@+id/ivQRCode"
                android:layout_width="@dimen/vs_300"
                android:layout_height="@dimen/vs_300"
                android:layout_gravity="center"
                android:focusable="false" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="@dimen/vs_300"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_10"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/color_CC000000"
                android:textSize="@dimen/ts_20"
                tools:text="http://192.168.1.1:9978" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="@dimen/vs_480"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/vs_20"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推送链接"
                android:textColor="@color/color_CC000000"
                android:textSize="@dimen/ts_26" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/storeList"
                android:layout_width="match_parent"
                android:layout_height="@dimen/vs_180"
                android:layout_marginTop="@dimen/vs_10"
                android:nextFocusDown="@id/inputName"
                android:orientation="vertical"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_verticalSpacingWithMargins="@dimen/vs_8" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_10"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/inputName"
                    android:layout_width="@dimen/vs_0"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/vs_5"
                    android:layout_weight="1"
                    android:background="@drawable/input_dialog_api_input"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="输入名字"
                    android:inputType="text"
                    android:maxLines="1"
                    android:nextFocusRight="@id/inputUrl"
                    android:nextFocusDown="@id/storagePermission"
                    android:paddingLeft="@dimen/vs_8"
                    android:paddingTop="@dimen/vs_10"
                    android:paddingRight="@dimen/vs_8"
                    android:paddingBottom="@dimen/vs_10"
                    android:textColor="@color/color_CC000000"
                    android:textColorHint="@color/color_6C3D3D3D"
                    android:textSize="@dimen/ts_22" />

                <EditText
                    android:id="@+id/inputUrl"
                    android:layout_width="@dimen/vs_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:background="@drawable/input_dialog_api_input"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="输入推送链接"
                    android:inputType="text"
                    android:maxLines="1"
                    android:nextFocusLeft="@id/inputName"
                    android:nextFocusDown="@id/inputSubmit"
                    android:paddingLeft="@dimen/vs_8"
                    android:paddingTop="@dimen/vs_10"
                    android:paddingRight="@dimen/vs_8"
                    android:paddingBottom="@dimen/vs_10"
                    android:textColor="@color/color_CC000000"
                    android:textColorHint="@color/color_6C3D3D3D"
                    android:textSize="@dimen/ts_22" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_10"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/storagePermission"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/vs_10"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:nextFocusRight="@id/inputSubmit"
                    android:nextFocusUp="@id/inputName"
                    android:gravity="center"
                    android:padding="@dimen/vs_10"
                    android:text="存储权限"
                    android:textColor="@color/color_FFFFFF"
                    android:textSize="@dimen/ts_22" />

                <TextView
                    android:id="@+id/inputSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:nextFocusLeft="@id/storagePermission"
                    android:nextFocusUp="@id/inputUrl"
                    android:gravity="center"
                    android:padding="@dimen/vs_10"
                    android:text="确定"
                    android:textColor="@color/color_FFFFFF"
                    android:textSize="@dimen/ts_22" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
